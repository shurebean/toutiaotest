{
  "apps": [
    {
      "name": "toutiao-backend",
      "script": "index-api.js",
      "cwd": "/home/toutiaotest/backend",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "max_memory_restart": "1G",
      "env": {
        "NODE_ENV": "production",
        "PORT": 5000
      },
      "error_file": "/home/toutiaotest/logs/backend-error.log",
      "out_file": "/home/toutiaotest/logs/backend-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss",
      "merge_logs": true,
      "autorestart": true,
      "max_restarts": 10,
      "restart_delay": 4000
    }
  ]
}
